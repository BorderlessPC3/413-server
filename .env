PORT=3000

# Mercado Pago (obrigatorio)
MP_ACCESS_TOKEN=cole_aqui_o_access_token
MP_PUBLIC_KEY=cole_aqui_a_public_key

# Seguranca da API (recomendado)
SERVER_API_KEY=defina_uma_chave_forte_para_o_app

# Frontend e CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Retorno do checkout
